<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.misstilo.cloth_erp_api.mapper.sale.SalesPlatformMapper">
  <!-- Result Map for SalesPlatform -->
  <resultMap id="SalesPlatformResultMap" type="com.misstilo.cloth_erp_api.model.sale.SalesPlatformModel">
    <id column="Id" property="id" />
    <result column="Name" property="name" />
  </resultMap>

  <!-- Insert -->
  <insert id="insert">
    INSERT INTO SalesPlatform (Name)
    VALUES (#{name})
  </insert>
  <!-- Delete -->
  <delete id="delete">
    DELETE FROM SalesPlatform
    WHERE id = #{id}
  </delete>
  <!-- Update -->
  <update id="update">
    UPDATE SalesPlatform
    <if test="name != null">
      <set>
        Name = #{name}
      </set>
    </if>
    <where>
      Id = #{id}
    </where>
  </update>
  <!-- Select -->
  <select id="select" resultMap="SalesPlatformResultMap">
    SELECT *
    FROM SalesPlatform
    <where>
      <if test="id != null">
        AND Id = #{id}
      </if>
      <if test="name != null and name != ''">
        AND Name = #{name}
      </if>
    </where>
    ORDER BY Id
  </select>
</mapper>