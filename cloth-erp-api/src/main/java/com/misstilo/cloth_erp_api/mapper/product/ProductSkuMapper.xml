<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.misstilo.cloth_erp_api.mapper.product.ProductSkuMapper">
  <!-- Result Map for ProductSku -->
  <resultMap id="productSkuResultMap" type="com.misstilo.cloth_erp_api.model.product.ProductSkuModel">
    <id column="Id" property="id" />
    <result column="ProductId" property="productId" />
    <result column="ProductName" property="productName" />
    <result column="SupplierId" property="supplierId" />
    <result column="SupplierName" property="supplierName" />
    <result column="ColorId" property="colorId" />
    <result column="ColorName" property="colorName" />
    <result column="SizeId" property="sizeId" />
    <result column="SizeName" property="sizeName" />
    <result column="SkuCode" property="skuCode" />
    <result column="CostPrc" property="costPrc" />
    <result column="IsActive" property="isActive" />
  </resultMap>

  <!-- Insert -->
  <insert id="insert">
    INSERT INTO ProductSku (ProductId, SupplierId, ColorId, SizeId, SkuCode, CostPrc, IsActive)
    VALUES (#{productId}, #{supplierId}, #{colorId}, #{sizeId}, #{skuCode}, #{costPrc}, #{isActive})
  </insert>
  <!-- Delete -->
  <delete id="delete">
    DELETE FROM ProductSku
    WHERE id = #{id}
  </delete>
  <!-- Update -->
  <update id="update">
    UPDATE ProductSku
    <if test="costPrc != null">
      <set>
        CostPrc = #{costPrc}
      </set>
    </if>
    <if test="isActive != null">
      <set>
        IsActive = #{isActive}
      </set>
    </if>
    <where>
      Id = #{id}
    </where>
  </update>
  <!-- Select -->
  <select id="select" resultMap="productSkuResultMap">
    SELECT PS.*, S.Name AS SupplierName, C.Name AS ColorName, Z.Name AS SizeName
    FROM ProductSku AS PS
    INNER JOIN Product AS P ON PS.ProductId = P.Id
    INNER JOIN Supplier AS S ON PS.SupplierId = S.Id
    INNER JOIN Color AS C ON PS.ColorId = C.Id
    INNER JOIN Size AS Z ON PS.SizeId = Z.Id
    <where>
      productId = #{productId}
    </where>
    ORDER BY Id
  </select>
</mapper>