<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.misstilo.cloth_erp_api.mapper.purchase.PurchaseOrderDetailMapper">
  <!-- Result Map for PurchaseOrderDetail -->
  <resultMap id="purchaseOrderDetailResultMap" type="com.misstilo.cloth_erp_api.model.purchase.PurchaseOrderDetailModel">
    <id column="Id" property="id" />
    <result column="PurchaseOrderId" property="purchaseOrderId" />
    <result column="ProductSkuId" property="productSkuId" />
    <result column="ProductSku" property="productSku" />
    <result column="ProductSkuName" property="productSkuName" />
    <result column="PurchaseQty" property="purchaseQty" />
    <result column="ReceivedQty" property="receivedQty" />
    <result column="UndeliveredQty" property="undeliveredQty" />
    <result column="CostPrc" property="costPrc" />
    <result column="SubTot" property="subTot" />
  </resultMap>

  <!-- Insert -->
  <insert id="insert">
    INSERT INTO PurchaseOrderDetail (PurchaseOrderId, ProductSkuId, PurchaseQty, CostPrc)
    VALUES (#{purchaseOrderId}, #{productSkuId}, #{purchaseQty}, #{costPrc})
  </insert>
  <!-- Delete -->
  <delete id="delete">
    DELETE FROM PurchaseOrderDetail
    WHERE Id = #{id}
  </delete>
  <!-- Update -->
  <update id="update">
    UPDATE PurchaseOrderDetail
    <if test="purchaseQty != null">
      <set>
        PurchaseQty = #{purchaseQty}
      </set>
    </if>
    <if test="costPrc != null">
      <set>
        CostPrc = #{costPrc}
      </set>
    </if>
    <where>
      Id = #{id}
    </where>
  </update>
  <!-- Select -->
  <select id="select" resultMap="purchaseOrderDetailResultMap">
    SELECT POD.*, PS.Name AS ProductSkuName, PS.SkuCode AS ProductSku
    FROM PurchaseOrderDetail AS POD
    INNER JOIN ProductSku AS PS ON POD.ProductSkuId = PS.Id
    <where>
      POD.PurchaseOrderId = #{purchaseOrderId}
    </where>
    ORDER BY Id
  </select>
</mapper>